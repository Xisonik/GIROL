{
  "run": {
    "name": "sac_concat",
    "algo": "sac",
    "task_name": "Aloha_nav",
    "seed": 42,
    "num_envs": 128,
    "timesteps": 10000,
    "headless": true,
    "video": false,
    "eval": false,
    "folder": "05.18_16-17-32_cur",
    "write_interval": 10,
    "checkpoint_interval": 1000
  },
  "agent": {
    "memory_size": 2000,
    "gradient_steps": 1,
    "batch_size": 512,
    "gamma": 0.99,
    "polyak": 0.005,
    "actor_learning_rate": 0.0003,
    "critic_learning_rate": 0.0003,
    "random_timesteps": 0,
    "learning_starts": 100,
    "grad_norm_clip": 0.0,
    "learn_entropy": true,
    "entropy_learning_rate": 0.005,
    "initial_entropy_value": 1.0,
    "normalize_img": true
  },
  "model": {
    "recurrent": {
      "enabled": false
    },
    "features": {
      "use_img": true,
      "use_memory": false,
      "use_goal": true,
      "use_gt_orientation": false,
      "use_graph": true,
      "graph_ref": "graph_encoder",
      "graph_dim": 128,
      "use_orientation_module": false,
      "orientation_ref": "orientation_module",
      "orientation_dim": 1
    },
    "modules": {
      "graph_encoder": {
        "class_path": "perception.graph_encoder.GraphEncoder",
        "kwargs": {
          "embeddings_path": {
            "cfg": "paths.text_embeddings"
          },
          "graphs_dir": {
            "cfg": "paths.graphs_dir"
          },
          "out_dim": 128,
          "dropout": 0.1
        },
        "eval": true
      },
      "orientation_module": {
        "class_path": "perception.orientation_module.OrientationFeature",
        "kwargs": {
          "mode": "pred",
          "img_dim": {
            "obs_dim": "img"
          },
          "graph_emb_dim": 128,
          "force_predictor": true,
          "log_metrics": false
        },
        "eval": true
      }
    },
    "policy": {
      "class_path": "models.sac_models.SACNavPolicy",
      "kwargs": {
        "hidden_dims": [
          256
        ]
      }
    },
    "q_critic": {
      "class_path": "models.sac_models.SACNavQCritic",
      "kwargs": {
        "hidden_dims": [
          256
        ]
      }
    }
  },
  "aux": {
    "enabled": true,
    "class_path": "perception.aux_trainer.OrientationAuxTrainer",
    "kwargs": {
      "graph_ref": "graph_encoder",
      "orientation_ref": "orientation_module",
      "lr_graph": 3e-05,
      "lr_orient": 3e-05,
      "batch_size": 256,
      "train_steps_per_call": 1,
      "log_interval": 50,
      "grad_norm_clip": 1.0
    }
  },
  "env": {
    "task": "nav",
    "turn_task": false,
    "camera": true,
    "memory": false,
    "controller": false,
    "curriculum": false
  },
  "paths": {
    "text_embeddings": "source/isaaclab_tasks/isaaclab_tasks/direct/aloha_nav/text_embeddings.pt",
    "graphs_dir": "/home/xiso/IsaacLab/eval_scenes_new_sgg2",
    "log_root": "logs/skrl"
  },
  "meta": {
    "base_config": "/home/xiso/IsaacLab/scripts/algos/configs/cur/base.json",
    "experiment_config": "/home/xiso/IsaacLab/scripts/algos/configs/cur/00_sac_concat_gic.json",
    "experiment": "00_sac_concat_gic",
    "experiment_grid_id": 0,
    "sweep": {
      "run.seed": 42
    },
    "config_index": 0,
    "config_total": 2
  }
}