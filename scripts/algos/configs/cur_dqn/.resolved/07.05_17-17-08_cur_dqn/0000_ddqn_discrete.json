{
  "run": {
    "name": "ddqn_discrete",
    "task_name": "Aloha_nav_hab_wr",
    "seed": 42,
    "num_envs": 32,
    "headless": true,
    "video": false,
    "eval": false,
    "folder": "07.05_17-17-08_cur_dqn",
    "write_interval": 10,
    "checkpoint_interval": 1000,
    "algo": "ddqn",
    "timesteps": 1000000
  },
  "agent": {
    "memory_size": 4000,
    "gradient_steps": 1,
    "batch_size": 512,
    "gamma": 0.99,
    "polyak": 0.005,
    "learning_rate": 0.0003,
    "random_timesteps": 1000,
    "learning_starts": 1000,
    "update_interval": 1,
    "target_update_interval": 10,
    "normalize_img": true
  },
  "model": {
    "recurrent": {
      "enabled": false
    },
    "features": {
      "use_img": true,
      "use_memory": false,
      "use_goal": true,
      "use_gt_orientation": false,
      "use_graph": true,
      "graph_ref": "graph_encoder",
      "graph_dim": 128,
      "use_orientation_module": false,
      "orientation_ref": "orientation_module",
      "orientation_dim": 1
    },
    "modules": {
      "graph_encoder": {
        "class_path": "perception.graph_encoder.GraphEncoder",
        "kwargs": {
          "embeddings_path": {
            "cfg": "paths.text_embeddings"
          },
          "graphs_dir": {
            "cfg": "paths.graphs_dir"
          },
          "out_dim": 128,
          "dropout": 0.1
        },
        "eval": true
      },
      "orientation_module": {
        "class_path": "perception.orientation_module.OrientationFeature",
        "kwargs": {
          "mode": "pred",
          "img_dim": {
            "obs_dim": "img"
          },
          "graph_emb_dim": 128,
          "force_predictor": true,
          "log_metrics": false
        },
        "eval": true
      }
    },
    "q_network": {
      "class_path": "models.ddqn_models.DDQNNavQNetwork",
      "kwargs": {
        "hidden_dims": [
          256
        ]
      }
    }
  },
  "aux": {
    "enabled": false,
    "class_path": "perception.aux_trainer.OrientationAuxTrainer",
    "kwargs": {
      "graph_ref": "graph_encoder",
      "orientation_ref": "orientation_module",
      "lr_graph": 3e-05,
      "lr_orient": 3e-05,
      "batch_size": 256,
      "train_steps_per_call": 1,
      "log_interval": 50,
      "grad_norm_clip": 1.0,
      "save_interval": {
        "cfg": "aux.save_interval"
      },
      "save_optimizer": {
        "cfg": "aux.save_optimizer"
      }
    },
    "save_interval": 1000,
    "save_optimizer": true,
    "log_env_metrics": true
  },
  "env": {
    "task": "hab_nav_wr",
    "turn_task": false,
    "action_angle_deg": 20,
    "camera": true,
    "memory": false,
    "expert": true,
    "curriculum": true
  },
  "paths": {
    "text_embeddings": "source/isaaclab_tasks/isaaclab_tasks/direct/aloha_nav/text_embeddings.pt",
    "graphs_dir": "/home/xiso/IsaacLab/eval_scenes_new_sgg2",
    "log_root": "logs/skrl",
    "aux_checkpoint": null,
    "agent_checkpoint": null,
    "state_preprocessor_checkpoint": null
  },
  "meta": {
    "base_config": "/home/xiso/IsaacLab/scripts/algos/configs/cur_dqn/base.json",
    "experiment_config": "/home/xiso/IsaacLab/scripts/algos/configs/cur_dqn/ddqn_discrete.json",
    "experiment": "ddqn_discrete",
    "experiment_grid_id": 0,
    "sweep": {},
    "config_index": 0,
    "config_total": 1
  }
}