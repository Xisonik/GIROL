{
  "run": {
    "name": "ddqn_discrete",
    "algo": "ddqn",
    "task_name": "Aloha_nav_hab_wr",
    "seed": 42,
    "num_envs": 32,
    "headless": true,
    "video": true,
    "eval": true,
    "folder": "debug",
    "write_interval": 10,
    "checkpoint_interval": 1000,
    "timesteps": 2000
  },
  "agent": {
    "memory_size": 4000,
    "gradient_steps": 1,
    "batch_size": 512,
    "gamma": 0.99,
    "polyak": 0.005,
    "learning_rate": 0.0003,
    "random_timesteps": 1000,
    "learning_starts": 1000,
    "update_interval": 1,
    "target_update_interval": 10,
    "normalize_img": true
  },
  "model": {
    "recurrent": {
      "enabled": false
    },
    "features": {
      "use_img": true,
      "use_memory": false,
      "use_goal": true,
      "use_gt_orientation": true,
      "use_graph": true,
      "graph_ref": "graph_encoder",
      "graph_dim": 128,
      "use_orientation_module": false,
      "orientation_ref": "orientation_module",
      "orientation_dim": 1
    },
    "modules": {
      "graph_encoder": {
        "class_path": "perception.graph_encoder.GraphEncoder",
        "kwargs": {
          "embeddings_path": {
            "cfg": "paths.text_embeddings"
          },
          "graphs_dir": {
            "cfg": "paths.graphs_dir"
          },
          "out_dim": 128,
          "dropout": 0.1
        },
        "eval": true
      },
      "orientation_module": {
        "class_path": "perception.orientation_module.OrientationFeature",
        "kwargs": {
          "mode": "pred",
          "img_dim": {
            "obs_dim": "img"
          },
          "graph_emb_dim": 128,
          "force_predictor": true,
          "log_metrics": false
        },
        "eval": true
      }
    },
    "q_network": {
      "class_path": "models.ddqn_models.DDQNNavQNetwork",
      "kwargs": {
        "hidden_dims": {
          "$value": [256]
        }
      }
    }
  },
  "aux": {
    "enabled": true
  },
  "env": {
    "task": "hab_nav_wr",
    "turn_task": false,
    "action_angle_deg": 20,
    "camera": true,
    "memory": false,
    "expert": true,
    "curriculum": true
  },
  "paths": {
    "text_embeddings": "source/isaaclab_tasks/isaaclab_tasks/direct/aloha_nav/text_embeddings.pt",
    "graphs_dir": "/home/xiso/IsaacLab/eval_scenes_new_sgg2",
    "log_root": "logs/skrl",
    "agent_checkpoint": "logs/skrl/Aloha_nav_hab_wr/07.19_16-15-31_cur_dqn/ddqn_discrete/checkpoints/best_agent.pt",
    "state_preprocessor_checkpoint": "logs/skrl/Aloha_nav_hab_wr/07.19_16-15-31_cur_dqn/ddqn_discrete/checkpoints/state_preprocessor_latest.pt",
    "aux_checkpoint": "logs/skrl/Aloha_nav_hab_wr/07.19_16-15-31_cur_dqn/ddqn_discrete/aux_checkpoints/aux_latest.pt"
  }
}
