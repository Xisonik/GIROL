{
  "run": {
    "name": "lstm_algos",
    "algo": "a2c",
    "task_name": "Aloha_nav_hab_wr",
    "seed": [
      42,
      13
    ],
    "num_envs": [
      16,
      32,
      64
    ],
    "timesteps": 3000,
    "headless": true,
    "video": false,
    "eval": false,
    "folder": "debug",
    "write_interval": 10,
    "checkpoint_interval": 1000
  },
  "agent": {},
  "model": {
    "recurrent": {
      "enabled": true,
      "sequence_length": 16
    },
    "features": {
      "use_img": true,
      "use_memory": false,
      "use_goal": false,
      "use_gt_orientation": true,
      "use_graph": true,
      "graph_ref": "graph_encoder",
      "graph_dim": 128,
      "use_orientation_module": false,
      "orientation_ref": "orientation_module",
      "orientation_dim": 1
    },
    "modules": {
      "graph_encoder": {
        "class_path": "perception.graph_encoder.GraphEncoder",
        "kwargs": {
          "embeddings_path": {
            "cfg": "paths.text_embeddings"
          },
          "graphs_dir": {
            "cfg": "paths.graphs_dir"
          },
          "out_dim": 128,
          "dropout": 0.1
        },
        "eval": true
      },
      "orientation_module": {
        "class_path": "perception.orientation_module.OrientationFeature",
        "kwargs": {
          "mode": "pred",
          "img_dim": {
            "obs_dim": "img"
          },
          "graph_emb_dim": 128,
          "force_predictor": true,
          "log_metrics": false
        },
        "eval": true
      }
    }
  },
  "aux": {
    "enabled": false,
    "class_path": "perception.aux_trainer.OrientationAuxTrainer",
    "kwargs": {
      "graph_ref": "graph_encoder",
      "orientation_ref": "orientation_module",
      "lr_graph": 3e-05,
      "lr_orient": 3e-05,
      "batch_size": 256,
      "train_steps_per_call": 1,
      "log_interval": 50,
      "grad_norm_clip": 1.0
    }
  },
  "env": {
    "task": "hab_nav",
    "turn_task": true,
    "action_angle_deg": 35,
    "camera": true,
    "memory": true,
    "controller": false,
    "curriculum": false
  },
  "paths": {
    "text_embeddings": "source/isaaclab_tasks/isaaclab_tasks/direct/aloha_nav/text_embeddings.pt",
    "graphs_dir": "/home/xiso/IsaacLab/eval_scenes_new_sgg2",
    "log_root": "logs/skrl"
  }
}