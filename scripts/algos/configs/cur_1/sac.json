{
  "run": {
    "algo": "sac",
    "name": "sac_continuous",
    "timesteps": 100000,
    "task_name": "Aloha_nav"
  },
  "agent": {
    "memory_size": 2000,
    "gradient_steps": 1,
    "batch_size": 512,
    "gamma": 0.99,
    "polyak": 0.005,
    "actor_learning_rate": 0.0003,
    "critic_learning_rate": 0.0003,
    "random_timesteps": 0,
    "learning_starts": 100,
    "grad_norm_clip": 0.0,
    "learn_entropy": true,
    "entropy_learning_rate": 0.005,
    "initial_entropy_value": 1.0,
    "normalize_img": true
  },
  "model": {
    "critic_hidden_dims_from_actor": false,
    "critic_branch_kwargs_from_actor": false,
    "recurrent": {
      "enabled": false
    },
    "features": {
      "gt_orientation_step_end": 4000,
      "noise_orientation_steps_start_step": 15000,
      "use_img": true,
      "use_memory": false,
      "use_goal": true,
      "use_gt_orientation": true,
      "use_gt_orientation_only": false,
      "use_graph": true,
      "graph_ref": "graph_encoder",
      "graph_dim": 128,
      "use_orientation_module": false,
      "orientation_ref": "orientation_module",
      "orientation_dim": 1
    },
    "policy": {
      "class_path": "models.sac_models.SACNavPolicy",
      "kwargs": {
        "hidden_dims": {
          "$value": [
            256
          ]
        }
      }
    },
    "q_critic": {
      "class_path": "models.sac_models.SACNavQCritic",
      "kwargs": {
        "hidden_dims": {
          "$value": [
            256
          ]
        }
      }
    }
  },
  "env": {
    "turn_task": false,
    "controller": false
  },
  "aux": {
    "enabled": true
  },
  "paths": {
    "agent_checkpoint": null,
    "state_preprocessor_checkpoint": null,
    "aux_checkpoint": null
  }
}