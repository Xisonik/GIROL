{
  "run": {
    "algo": "a2c",
    "name": "a2c_concat_lstm",
    "timesteps": 8000
  },
  "agent": {
    "rollouts": 128,
    "mini_batches": 32,
    "learning_rate": 0.0003,
    "gamma": 0.96,
    "gae_lambda": 0.92,
    "grad_norm_clip": 1.0,
    "entropy_loss_scale": 0.001,
    "random_timesteps": 0,
    "normalize_img": true
  },
  "model": {
    "critic_hidden_dims_from_actor": true,
    "critic_branch_kwargs_from_actor": false,
    "recurrent": {
      "enabled": true
    },
    "features": {
      "gt_orientation_step_end": 6000,
      "noise_orientation_steps_start_step": 4000,
      "use_img": false,
      "use_memory": false,
      "use_goal": true,
      "use_gt_orientation": true,
      "use_graph": false,
      "graph_ref": "graph_encoder",
      "graph_dim": 128,
      "use_orientation_module": false,
      "orientation_ref": "orientation_module",
      "orientation_dim": 1
    },
    "actor": {
      "class_path": "models.a2c_models_lstm.make_a2c_nav_lstm_actor",
      "kwargs": {
        "hidden_dims": {
          "$value": [
            32
          ]
        },
        "lstm_hidden_size": 32,
        "lstm_num_layers": 1,
        "sequence_length": 16
      }
    },
    "critic": {
      "class_path": "models.a2c_models_lstm.A2CNavLSTMValue",
      "kwargs": {
        "hidden_dims": {
          "$value": [
            32
          ]
        },
        "lstm_hidden_size": 32,
        "lstm_num_layers": 1,
        "sequence_length": 16
      }
    }
  }
}