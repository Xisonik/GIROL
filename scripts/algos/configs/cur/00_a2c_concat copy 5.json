{
  "run": {
    "algo": "ppo",
    "name": "ppo_concat_lstm",
    "timesteps": 350000
  },
  "agent": {
    "rollouts": 128,
    "learning_epochs": 8,
    "mini_batches": 8,
    "learning_rate": 0.0003,
    "gamma": 0.96,
    "gae_lambda": 0.92,
    "grad_norm_clip": 1.0,
    "ratio_clip": 0.2,
    "value_clip": 0.2,
    "entropy_loss_scale": 0.001,
    "value_loss_scale": 2.5,
    "kl_threshold": 0.0,
    "random_timesteps": 0,
    "learning_starts": 0,
    "normalize_img": true
  },
  "model": {
    "critic_hidden_dims_from_actor": false,
    "critic_branch_kwargs_from_actor": false,
    "recurrent": {
      "enabled": true,
      "sequence_length": 16
    },
    "features": {
      "gt_orientation_step_end": 4000,
      "noise_orientation_steps_start_step": 150000,
      "use_img": true,
      "use_memory": false,
      "use_goal": true,
      "use_gt_orientation": false,
      "use_graph": true,
      "graph_ref": "graph_encoder",
      "graph_dim": 128,
      "use_orientation_module": false,
      "orientation_ref": "orientation_module",
      "orientation_dim": 1
    },
    "actor": {
      "class_path": "models.a2c_models_lstm.make_a2c_nav_lstm_actor",
      "kwargs": {
        "hidden_dims": {
          "$value": [
            256
          ]
        },
        "lstm_hidden_size": 32,
        "lstm_num_layers": 1,
        "sequence_length": 16
      }
    },
    "critic": {
      "class_path": "models.a2c_models_lstm.A2CNavLSTMValue",
      "kwargs": {
        "hidden_dims": {
          "$value": [
            256
          ]
        },
        "lstm_hidden_size": 32,
        "lstm_num_layers": 1,
        "sequence_length": 16
      }
    }
  },
  "paths": {
    "aux_checkpoint": null,
    "agent_checkpoint": null,
    "state_preprocessor_checkpoint": null
  }
}